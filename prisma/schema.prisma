generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  USER
  ADMIN
}

enum ApplicationStatus {
  APPLIED
  ONLINE_ASSESSMENT
  INTERVIEW
  OFFERED
  REJECTED
  WITHDRAWN
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// PlaceTrack User Model
model User {
  id            String    @id @default(cuid()) // Will store Clerk User ID
  name          String?
  email         String?   @unique
  image         String?
  role          Role      @default(USER)
  banned        Boolean   @default(false)
  lastActiveAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  applications Application[]
  experiences  Experience[]
  votes        Vote[]
  reports      Report[]
}
// PlaceTrack Core Models

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  website   String?
  logo      String?
  industry  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications Application[]
  experiences  Experience[]

  @@index([name])
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  companyId String
  role      String
  status    ApplicationStatus @default(APPLIED)
  location       String?
  salary         String?
  appliedAt      DateTime          @default(now())
  assessmentDate DateTime?
  interviewDate  DateTime?
  remindersSent  String[]          @default([])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
}

model Experience {
  id                 String   @id @default(cuid())
  title              String
  role               String   @default("Unknown")
  content            String   @db.Text
  oaQuestions        String?  @db.Text
  interviewQuestions String?  @db.Text
  tips               String?  @db.Text
  tags               String[] @default([])
  rating             Int      @default(0) // 1 to 5 scale
  difficulty         Int      @default(0) // 1 to 5 scale
  year               Int      @default(2024)
  offerStatus String? // Optional field, e.g., Offered, Rejected
  isAnonymous Boolean  @default(false)
  upvotes     Int      @default(0)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    String
  companyId String

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  votes   Vote[]
  reports Report[]

  @@index([companyId])
  @@index([createdAt])
  @@index([userId])
}

model Vote {
  id        String   @id @default(cuid())
  value     VoteType
  createdAt DateTime @default(now())

  userId       String
  experienceId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([userId, experienceId])
  @@index([experienceId])
}

model Report {
  id        String       @id @default(cuid())
  reason    String       @db.Text
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  reporterId   String
  experienceId String

  reporter   User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([experienceId])
}

model ExternalResource {
  id          String   @id @default(cuid())
  title       String
  summary     String?  @db.Text
  url         String   @unique
  source      String   // e.g., "YouTube", "Medium", "GeeksforGeeks"
  company     String?  
  role        String?
  tags        String[] @default([])
  fetchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([company])
}
